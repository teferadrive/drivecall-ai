{
  "expo": {
    "name": "DriveCall AI",
    "slug": "mobile-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile-template",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2f4f8"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ExpoLocalization_supportsRTL": true,
        "ExpoLocalization_forcesRTL": true
      },
      "bundleIdentifier": "com.yourname.yourapp"
    },
    "android": {
      "package": "com.drivinginstructor.callassistant",
      "permissions": [
        "READ_PHONE_STATE",
        "READ_CALL_LOG",
        "POST_NOTIFICATIONS",
        "CALL_PHONE",
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f2f4f8"
      },
      "edgeToEdgeEnabled": false
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#0a0a0a"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-localization",
        {
          "supportsRTL": true,
          "forcesRTL": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe0b65db-c1ec-49e0-ac69-33e62357cdc6"
      }
    },
    "owner": "asnakew"
  }
}
